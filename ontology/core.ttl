@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix nfl:    <urn:nfl:> .
@prefix team:   <urn:nfl:team:> .
@prefix game:   <urn:nfl:game:> .
@prefix outcome: <urn:nfl:outcome:> .
@prefix user:   <urn:nfl:user:> .

# ─────────────────────────────────────────
# Core Classes
# ─────────────────────────────────────────

nfl:Team a owl:Class ;
    rdfs:label "NFL Team" ;
    rdfs:comment "An NFL franchise that is a first-class holon in the knowledge graph." .

nfl:Game a owl:Class ;
    rdfs:label "NFL Game" ;
    rdfs:comment "A scheduled or completed NFL game event." .

nfl:Outcome a owl:Class ;
    rdfs:label "Game Outcome" ;
    rdfs:comment "A possible or actual result of a game (win/loss/tie for a specific team)." .

nfl:User a owl:Class ;
    rdfs:label "User" ;
    rdfs:comment "A system user with team preferences." .

nfl:Conference a owl:Class ;
    rdfs:label "Conference" ;
    rdfs:comment "AFC or NFC." .

nfl:Division a owl:Class ;
    rdfs:label "Division" ;
    rdfs:comment "One of the eight NFL divisions." .

nfl:Week a owl:Class ;
    rdfs:label "Week" ;
    rdfs:comment "An NFL schedule week." .

# ─────────────────────────────────────────
# Core Team Properties
# ─────────────────────────────────────────

nfl:name       a owl:DatatypeProperty ; rdfs:domain nfl:Team ; rdfs:range xsd:string .
nfl:abbreviation a owl:DatatypeProperty ; rdfs:domain nfl:Team ; rdfs:range xsd:string .
nfl:location   a owl:DatatypeProperty ; rdfs:domain nfl:Team ; rdfs:range xsd:string .
nfl:wins       a owl:DatatypeProperty ; rdfs:range xsd:integer .
nfl:losses     a owl:DatatypeProperty ; rdfs:range xsd:integer .
nfl:ties       a owl:DatatypeProperty ; rdfs:range xsd:integer .
nfl:winPct     a owl:DatatypeProperty ; rdfs:range xsd:float .
nfl:pointsFor  a owl:DatatypeProperty ; rdfs:range xsd:integer .
nfl:pointsAgainst a owl:DatatypeProperty ; rdfs:range xsd:integer .
nfl:seed       a owl:DatatypeProperty ; rdfs:range xsd:integer .

nfl:conference    a owl:ObjectProperty ; rdfs:domain nfl:Team ; rdfs:range nfl:Conference .
nfl:division      a owl:ObjectProperty ; rdfs:domain nfl:Team ; rdfs:range nfl:Division .
nfl:favoriteTeam  a owl:ObjectProperty ; rdfs:domain nfl:User ; rdfs:range nfl:Team .
nfl:dislikes      a owl:ObjectProperty ; rdfs:domain nfl:User ; rdfs:range nfl:Team .

# ─────────────────────────────────────────
# Core Game Properties
# ─────────────────────────────────────────

nfl:week          a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:integer .
nfl:season        a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:integer .
nfl:seasonType    a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:string .
nfl:homeTeam      a owl:ObjectProperty  ; rdfs:domain nfl:Game ; rdfs:range nfl:Team .
nfl:awayTeam      a owl:ObjectProperty  ; rdfs:domain nfl:Game ; rdfs:range nfl:Team .
nfl:homeScore     a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:integer .
nfl:awayScore     a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:integer .
nfl:status        a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:string .
nfl:startTime     a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:dateTime .
nfl:venue         a owl:DatatypeProperty ; rdfs:domain nfl:Game ; rdfs:range xsd:string .
nfl:espnId        a owl:DatatypeProperty ; rdfs:range xsd:string .
nfl:winner        a owl:ObjectProperty  ; rdfs:domain nfl:Game ; rdfs:range nfl:Team .
nfl:loser         a owl:ObjectProperty  ; rdfs:domain nfl:Game ; rdfs:range nfl:Team .
nfl:hasOutcome    a owl:ObjectProperty  ; rdfs:domain nfl:Game ; rdfs:range nfl:Outcome .

# ─────────────────────────────────────────
# Structural Hierarchy Properties
# ─────────────────────────────────────────

nfl:belongsTo     a owl:ObjectProperty .
nfl:contains      a owl:ObjectProperty .
nfl:memberOf      a owl:ObjectProperty .
nfl:conferenceOf  a owl:ObjectProperty .
nfl:divisionOf    a owl:ObjectProperty .

# ─────────────────────────────────────────
# Conference and Division Individuals
# ─────────────────────────────────────────

nfl:AFC a nfl:Conference ; nfl:name "AFC" .
nfl:NFC a nfl:Conference ; nfl:name "NFC" .

nfl:AFCNorth a nfl:Division ; nfl:name "AFC North" ; nfl:belongsTo nfl:AFC .
nfl:AFCSouth a nfl:Division ; nfl:name "AFC South" ; nfl:belongsTo nfl:AFC .
nfl:AFCEast  a nfl:Division ; nfl:name "AFC East"  ; nfl:belongsTo nfl:AFC .
nfl:AFCWest  a nfl:Division ; nfl:name "AFC West"  ; nfl:belongsTo nfl:AFC .
nfl:NFCNorth a nfl:Division ; nfl:name "NFC North" ; nfl:belongsTo nfl:NFC .
nfl:NFCSouth a nfl:Division ; nfl:name "NFC South" ; nfl:belongsTo nfl:NFC .
nfl:NFCEast  a nfl:Division ; nfl:name "NFC East"  ; nfl:belongsTo nfl:NFC .
nfl:NFCWest  a nfl:Division ; nfl:name "NFC West"  ; nfl:belongsTo nfl:NFC .
