@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix nfl:    <urn:nfl:> .
@prefix playoff: <urn:nfl:playoff:> .
@prefix impact:  <urn:nfl:impact:> .
@prefix recommendation: <urn:nfl:recommendation:> .

# ─────────────────────────────────────────
# Playoff Classes
# ─────────────────────────────────────────

playoff:PlayoffSpot a owl:Class ;
    rdfs:label "Playoff Spot" ;
    rdfs:comment "A specific seed or wildcard position available in the playoffs." .

playoff:Scenario a owl:Class ;
    rdfs:label "Playoff Scenario" ;
    rdfs:comment "A condition tree representing a future playoff state." .

# ─────────────────────────────────────────
# Playoff Spot Individuals
# ─────────────────────────────────────────
# AFC Seeds 1-7

playoff:AFCSeed1 a playoff:PlayoffSpot ; nfl:name "AFC Seed 1" ; nfl:conference nfl:AFC ; nfl:seed "1"^^xsd:integer .
playoff:AFCSeed2 a playoff:PlayoffSpot ; nfl:name "AFC Seed 2" ; nfl:conference nfl:AFC ; nfl:seed "2"^^xsd:integer .
playoff:AFCSeed3 a playoff:PlayoffSpot ; nfl:name "AFC Seed 3" ; nfl:conference nfl:AFC ; nfl:seed "3"^^xsd:integer .
playoff:AFCSeed4 a playoff:PlayoffSpot ; nfl:name "AFC Seed 4" ; nfl:conference nfl:AFC ; nfl:seed "4"^^xsd:integer .
playoff:AFCWildcard1 a playoff:PlayoffSpot ; nfl:name "AFC Wildcard 1" ; nfl:conference nfl:AFC ; nfl:seed "5"^^xsd:integer .
playoff:AFCWildcard2 a playoff:PlayoffSpot ; nfl:name "AFC Wildcard 2" ; nfl:conference nfl:AFC ; nfl:seed "6"^^xsd:integer .
playoff:AFCWildcard3 a playoff:PlayoffSpot ; nfl:name "AFC Wildcard 3" ; nfl:conference nfl:AFC ; nfl:seed "7"^^xsd:integer .

# NFC Seeds 1-7
playoff:NFCSeed1 a playoff:PlayoffSpot ; nfl:name "NFC Seed 1" ; nfl:conference nfl:NFC ; nfl:seed "1"^^xsd:integer .
playoff:NFCSeed2 a playoff:PlayoffSpot ; nfl:name "NFC Seed 2" ; nfl:conference nfl:NFC ; nfl:seed "2"^^xsd:integer .
playoff:NFCSeed3 a playoff:PlayoffSpot ; nfl:name "NFC Seed 3" ; nfl:conference nfl:NFC ; nfl:seed "3"^^xsd:integer .
playoff:NFCSeed4 a playoff:PlayoffSpot ; nfl:name "NFC Seed 4" ; nfl:conference nfl:NFC ; nfl:seed "4"^^xsd:integer .
playoff:NFCWildcard1 a playoff:PlayoffSpot ; nfl:name "NFC Wildcard 1" ; nfl:conference nfl:NFC ; nfl:seed "5"^^xsd:integer .
playoff:NFCWildcard2 a playoff:PlayoffSpot ; nfl:name "NFC Wildcard 2" ; nfl:conference nfl:NFC ; nfl:seed "6"^^xsd:integer .
playoff:NFCWildcard3 a playoff:PlayoffSpot ; nfl:name "NFC Wildcard 3" ; nfl:conference nfl:NFC ; nfl:seed "7"^^xsd:integer .

# ─────────────────────────────────────────
# Playoff Properties
# ─────────────────────────────────────────

nfl:competesFor     a owl:ObjectProperty ; rdfs:range playoff:PlayoffSpot .
nfl:currentlyHolds  a owl:ObjectProperty ; rdfs:range playoff:PlayoffSpot .
nfl:eliminated      a owl:DatatypeProperty ; rdfs:range xsd:boolean .
playoff:requires    a owl:ObjectProperty ; rdfs:domain playoff:Scenario .
playoff:beneficiary a owl:ObjectProperty ; rdfs:domain playoff:Scenario ; rdfs:range nfl:Team .

# ─────────────────────────────────────────
# Impact Classes & Properties
# ─────────────────────────────────────────

impact:ImpactEdge a owl:Class ;
    rdfs:label "Impact Edge" ;
    rdfs:comment "A weighted influence relationship between a game/outcome and a team's playoff position." .

impact:affects      a owl:ObjectProperty ; rdfs:label "affects" .
impact:helps        a owl:ObjectProperty ; rdfs:label "helps" ; rdfs:subPropertyOf impact:affects .
impact:harms        a owl:ObjectProperty ; rdfs:label "harms" ; rdfs:subPropertyOf impact:affects .
impact:improvesOdds a owl:ObjectProperty ; rdfs:label "improvesOdds" ; rdfs:subPropertyOf impact:helps .
impact:reducesOdds  a owl:ObjectProperty ; rdfs:label "reducesOdds"  ; rdfs:subPropertyOf impact:harms .
impact:controlsDestiny a owl:ObjectProperty ; rdfs:label "controlsDestiny" .
impact:score        a owl:DatatypeProperty ; rdfs:range xsd:float ;
    rdfs:comment "Normalized impact score 0.0–1.0." .
impact:weight       a owl:DatatypeProperty ; rdfs:range xsd:float ;
    rdfs:comment "Edge propagation weight." .

# ─────────────────────────────────────────
# Temporal Properties
# ─────────────────────────────────────────

nfl:nextGame        a owl:ObjectProperty ; rdfs:domain nfl:Game ; rdfs:range nfl:Game .
nfl:previousGame    a owl:ObjectProperty ; rdfs:domain nfl:Game ; rdfs:range nfl:Game .
nfl:futureScenario  a owl:ObjectProperty ; rdfs:range playoff:Scenario .
nfl:dependsOn       a owl:ObjectProperty .

# ─────────────────────────────────────────
# Recommendation Classes & Properties
# ─────────────────────────────────────────

nfl:Recommendation a owl:Class ;
    rdfs:label "Rooting Recommendation" ;
    rdfs:comment "A dynamically generated suggestion to root for a specific team in a game." .

nfl:rootFor         a owl:ObjectProperty ; rdfs:domain nfl:Recommendation ; rdfs:range nfl:Team .
nfl:against         a owl:ObjectProperty ; rdfs:domain nfl:Recommendation ; rdfs:range nfl:Team .
nfl:forGame         a owl:ObjectProperty ; rdfs:domain nfl:Recommendation ; rdfs:range nfl:Game .
nfl:benefitsTeam    a owl:ObjectProperty ; rdfs:domain nfl:Recommendation ; rdfs:range nfl:Team .
nfl:recommendationScore a owl:DatatypeProperty ; rdfs:domain nfl:Recommendation ; rdfs:range xsd:float .
nfl:reasoning       a owl:DatatypeProperty ; rdfs:domain nfl:Recommendation ; rdfs:range xsd:string .
nfl:shouldRootFor   a owl:ObjectProperty ; rdfs:domain nfl:User .
