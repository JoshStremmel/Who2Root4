{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@g3t/core":          ["../g3-toolkit/packages/core/src"],
      "@g3t/core/*":        ["../g3-toolkit/packages/core/src/*"],
      "@g3t/react":         ["../g3-toolkit/packages/react/src"],
      "@g3t/react/controls":["../g3-toolkit/packages/react/src/interaction/index.ts"],
      "@g3t/react/views":   ["../g3-toolkit/packages/react/src/views/index.ts"],
      "@g3t/react/state":   ["../g3-toolkit/packages/react/src/state/index.ts"],
      "@g3t/react/theme":   ["../g3-toolkit/packages/react/src/theme/index.ts"],
      "@g3t/charts":        ["../g3-toolkit/packages/charts/src"],
      "@g3t/charts/*":      ["../g3-toolkit/packages/charts/src/*"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true
  },
  "include": ["src", "../g3-toolkit/packages/react/src/types"]
}
